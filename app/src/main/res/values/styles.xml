<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ===== BASE APP THEME ===== -->
    <style name="Theme.PhongMay" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_violet</item>
        <item name="colorPrimaryVariant">@color/accent_violet_dim</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_amber</item>
        <item name="colorOnSecondary">@color/bg_deep</item>
        <item name="android:colorBackground">@color/bg_deep</item>
        <item name="android:windowBackground">@color/bg_deep</item>
        <item name="android:statusBarColor">@color/bg_deep</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- ===== TYPOGRAPHY ===== -->

    <style name="TextStyle.Display" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">32sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <style name="TextStyle.Title" parent="">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Label" parent="">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextStyle.Body" parent="">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextStyle.Muted" parent="">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextStyle.Accent" parent="">
        <item name="android:textColor">@color/accent_violet_light</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <style name="TextStyle.Amber" parent="">
        <item name="android:textColor">@color/accent_amber</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.03</item>
    </style>

    <!-- ===== INPUT FIELDS ===== -->

    <style name="InputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_elevated</item>
        <item name="boxStrokeColor">@color/border_medium</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="hintTextColor">@color/text_muted</item>
        <item name="android:textColorHint">@color/text_muted</item>
    </style>

    <style name="InputField.Focused" parent="InputField">
        <item name="boxStrokeColor">@color/accent_violet</item>
    </style>

    <!-- ===== BUTTONS ===== -->

    <style name="Btn.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/accent_violet</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Btn.Ghost" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/border_violet</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/accent_violet_light</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:backgroundTint">@color/transparent</item>
    </style>

    <style name="Btn.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Btn.TextAccent" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent_violet_light</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- ===== CARDS ===== -->

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/border_subtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="CardStyle.Elevated" parent="CardStyle">
        <item name="cardBackgroundColor">@color/bg_elevated</item>
        <item name="strokeColor">@color/border_medium</item>
    </style>

    <!-- ===== TABS ===== -->

    <style name="TabStyle" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabBackground">@color/transparent</item>
        <item name="tabSelectedTextColor">@color/text_primary</item>
        <item name="tabTextColor">@color/text_muted</item>
        <item name="tabIndicatorColor">@color/accent_violet</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabTextAppearance">@style/TabTextAppearance</item>
        <item name="tabGravity">fill</item>
        <item name="tabMode">scrollable</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- ===== BOTTOM NAVIGATION ===== -->

    <style name="BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_surface</item>
        <item name="itemIconTint">@color/bottom_nav_tint</item>
        <item name="itemTextColor">@color/bottom_nav_tint</item>
        <item name="itemRippleColor">@color/accent_violet_dim</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- ===== SECTION HEADERS ===== -->

    <style name="SectionHeader" parent="">
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.14</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- ===== LIST ITEM ROW ===== -->

    <style name="ListRowStyle" parent="">
        <item name="android:background">@drawable/bg_list_row</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- ===== STATUS CHIPS ===== -->

    <style name="Chip.Online" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">@color/status_online</item>
        <item name="chipBackgroundColor">@color/status_online_dim</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textSize">11sp</item>
        <item name="chipMinHeight">28dp</item>
    </style>

    <style name="Chip.Offline" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">@color/status_offline</item>
        <item name="chipBackgroundColor">@color/status_offline_dim</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textSize">11sp</item>
        <item name="chipMinHeight">28dp</item>
    </style>

</resources>
